# App
ENVIRONMENT=development
DEBUG=true

# Security — generate a real value with: openssl rand -hex 32
SECRET_KEY=replace-this-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://dreamforge:dreamforge@localhost:5432/dreamforge

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS — comma-separated origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

# Object storage (optional — falls back to mock URLs if unset)
STORAGE_ENDPOINT_URL=
STORAGE_BUCKET=dreamforge-media
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_BASE_URL=https://media.dreamforge.ai

# AI providers (optional — mock providers are used automatically when unset)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
STABILITY_API_KEY=
RUNWAY_API_KEY=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
